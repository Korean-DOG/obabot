{
  "bot_name": "RegistrationBot",
  "initial_state": "start",
  "states": {
    "start": {
      "text": "👋 Привет!\n\nДобро пожаловать в бота!\n\nВыберите действие:",
      "buttons": [
        [
          {"text": "📝 Регистрация", "data": "register"},
          {"text": "ℹ️ Информация", "data": "info"}
        ],
        [
          {"text": "📊 Статистика", "data": "stats"}
        ]
      ]
    },
    "waiting_name": {
      "text": "Как тебя зовут?",
      "buttons": [
        [
          {"text": "❌ Отмена", "data": "cancel"}
        ]
      ]
    },
    "waiting_email": {
      "text": "Отлично! Теперь введите email:",
      "buttons": [
        [
          {"text": "⬅️ Назад", "data": "back"},
          {"text": "❌ Отмена", "data": "cancel"}
        ]
      ]
    },
    "waiting_phone": {
      "text": "Теперь введите номер телефона:",
      "buttons": [
        [
          {"text": "⬅️ Назад", "data": "back"},
          {"text": "❌ Отмена", "data": "cancel"}
        ]
      ]
    },
    "info": {
      "text": "ℹ️ Информация о боте\n\nЭто демонстрационный бот для тестирования FSM coverage.",
      "buttons": [
        [
          {"text": "🏠 Главное меню", "data": "nav:main"}
        ]
      ]
    },
    "stats": {
      "text": "📊 Статистика\n\nВаша статистика будет здесь.",
      "buttons": [
        [
          {"text": "🏠 Главное меню", "data": "nav:main"}
        ]
      ]
    },
    "registration_complete": {
      "text": "✅ Регистрация завершена!\n\nСпасибо за регистрацию.",
      "buttons": [
        [
          {"text": "🏠 Главное меню", "data": "nav:main"}
        ]
      ]
    }
  },
  "transitions": [
    {
      "from": "start",
      "to": "waiting_name",
      "action": "callback:register",
      "label": "Регистрация"
    },
    {
      "from": "start",
      "to": "info",
      "action": "callback:info",
      "label": "Информация"
    },
    {
      "from": "start",
      "to": "stats",
      "action": "callback:stats",
      "label": "Статистика"
    },
    {
      "from": "waiting_name",
      "to": "waiting_email",
      "action": "text:*",
      "label": "Ввод имени"
    },
    {
      "from": "waiting_email",
      "to": "waiting_phone",
      "action": "text:*",
      "label": "Ввод email"
    },
    {
      "from": "waiting_phone",
      "to": "registration_complete",
      "action": "text:*",
      "label": "Ввод телефона"
    },
    {
      "from": "waiting_email",
      "to": "waiting_name",
      "action": "callback:back",
      "label": "Назад"
    },
    {
      "from": "waiting_phone",
      "to": "waiting_email",
      "action": "callback:back",
      "label": "Назад"
    },
    {
      "from": "waiting_name",
      "to": "start",
      "action": "callback:cancel",
      "label": "Отмена"
    },
    {
      "from": "waiting_email",
      "to": "start",
      "action": "callback:cancel",
      "label": "Отмена"
    },
    {
      "from": "waiting_phone",
      "to": "start",
      "action": "callback:cancel",
      "label": "Отмена"
    },
    {
      "from": "waiting_name",
      "to": "start",
      "action": "command:/cancel",
      "label": "Отмена командой"
    },
    {
      "from": "waiting_email",
      "to": "start",
      "action": "command:/cancel",
      "label": "Отмена командой"
    },
    {
      "from": "waiting_phone",
      "to": "start",
      "action": "command:/cancel",
      "label": "Отмена командой"
    },
    {
      "from": "info",
      "to": "start",
      "action": "callback:nav:main",
      "label": "Главное меню"
    },
    {
      "from": "stats",
      "to": "start",
      "action": "callback:nav:main",
      "label": "Главное меню"
    },
    {
      "from": "registration_complete",
      "to": "start",
      "action": "callback:nav:main",
      "label": "Главное меню"
    },
    {
      "from": "start",
      "to": "start",
      "action": "command:/start",
      "label": "Перезапуск"
    },
    {
      "from": "start",
      "to": "waiting_name",
      "action": "state_enter:waiting_name",
      "label": "Автовход (таймер)"
    }
  ]
}
